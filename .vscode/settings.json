{
  "latex-workshop.formatting.latex": "latexindent",   
  "ltex.enabled": true,
  "ltex.latex.environments": {
    "block": "default",
    "bibelbox": "default"
  },
  "ltex.latex.commands": {
    "bibleverse": "ignore",
    "lied": "default",
    "info": "default",
    "beten": "default",
    "betonung": "default"
  },
  "editor.overtypeCursorStyle": "line",
  "editor.cursorStyle": "line",
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/*.crswap": true,
    "**/*.aux": true,
    "**/*.bbl": true,
    "**/*.blg": true,
    "**/*-blx.bib": true,
    "**/*.fdb_latexmk": true,
    "**/*.log": true,
    "**/*.out": true,
    "**/*.toc": true,
    "**/*.gz": true,
    "**/*.fls": true,
  },
  "editor.wordWrap": "on"
  
}