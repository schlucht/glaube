{
  "latex-workshop.formatting.latex": "latexindent",
  "ltex.enabled": true,
  "ltex.latex.environments": {
    "block": "default",
    "bibelbox": "default"
  },
  "latex-workshop.latex.autoBuild.run": "never",
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk (lualatex)",
      "command": "latexmk",
      "args": [
        "-pdflua",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ]
    },
    {
      "name": "latexmk (xelatex)",
      "command": "latexmk",
      "args": [
        "-pdfxe",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "%DOC%"
      ]
    }
  ],
  "ltex.latex.commands": {
    "bibleverse": "ignore",
    "lied": "default",
    "info": "default",
    "beten": "default",
    "betonung": "default"
  },
  "latex-workshop.latex.recipes": [
    {
      "name": "LuaLaTeX",
      "tools": [
        "latexmk (lualatex)"
      ]
    },
    {
      "name": "XeLaTeX",
      "tools": [
        "latexmk (xelatex)"
      ]
    }
  ],
  "editor.overtypeCursorStyle": "line",
  "editor.cursorStyle": "line",
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/*.crswap": true,
    "**/*.aux": true,
    "**/*.bbl": true,
    "**/*.blg": true,
    "**/*-blx.bib": true,
    "**/*.fdb_latexmk": true,
    "**/*.log": true,
    "**/*.out": true,
    "**/*.toc": true,
    "**/*.gz": true,
    "**/*.fls": true,
    "**/*.xdv": true,
  },
  "editor.wordWrap": "on",
  "cSpell.words": [
    "Apero",
    "Birgisch"
  ]
}