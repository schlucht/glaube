% textmakro.sty
% Makros für grammatische und theologische Textmarkierung
% Autor: OTS
% Version: 1.0
% Verwendung: \makro{Text} für Textfarbe, \makro[b]{Text} für Box-Hintergrundfarbe

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{textmakro}[2026/02/28 Text-Markierungs-Makros]

\RequirePackage{colors}
\RequirePackage{xparse}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Boolean-Schalter für Farbmarkierungen (optional)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\ExplSyntaxOn

% Boolean-Variablen definieren
\bool_new:N \l_color_verb_bool
\bool_new:N \l_color_verbI_bool
\bool_new:N \l_color_verbP_bool
\bool_new:N \l_color_nomen_bool
\bool_new:N \l_color_konj_bool
\bool_new:N \l_color_ort_bool
\bool_new:N \l_color_person_bool
\bool_new:N \l_color_gott_bool
\bool_new:N \l_color_jesus_bool
\bool_new:N \l_color_geist_bool
\bool_new:N \l_color_israel_bool
\bool_new:N \l_color_teufel_bool

% Standardmäßig alle Farben aktiviert
\bool_set_true:N \l_color_verb_bool
\bool_set_true:N \l_color_verbI_bool
\bool_set_true:N \l_color_verbP_bool
\bool_set_true:N \l_color_nomen_bool
\bool_set_true:N \l_color_konj_bool
\bool_set_true:N \l_color_ort_bool
\bool_set_true:N \l_color_person_bool
\bool_set_true:N \l_color_gott_bool
\bool_set_true:N \l_color_jesus_bool
\bool_set_true:N \l_color_geist_bool
\bool_set_true:N \l_color_israel_bool
\bool_set_true:N \l_color_teufel_bool

\ExplSyntaxOff

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% VERBEN
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\ExplSyntaxOn

% Verb (Normal) - Grün rgb(50,205,50)
\NewDocumentCommand{\vb}{o m}{%
  \bool_if:NTF \l_color_verb_bool
    {
      \IfNoValueTF{#1}
        {\textcolor{verbcolor}{#2}}                    % Nur Textfarbe
        {\cbox{verbcolor}{white}{#2}}                  % Box-Hintergrund
    }
    {#2}                                               % Keine Farbe
}

% Verb (Imperativ) - Gelb rgb(255,255,0)
\NewDocumentCommand{\verbI}{o m}{%
  \bool_if:NTF \l_color_verbI_bool
    {
      \IfNoValueTF{#1}
        {\textcolor{verbimperativcolor}{#2}}                     % Nur Textfarbe
        {\cbox{verbimperativcolor}{black}{#2}}                   % Box-Hintergrund
    }
    {#2}                                                         % Keine Farbe
}

% Verb (Passiv) - Grün + Superscript P
\NewDocumentCommand{\verbP}{o m}{%
  \bool_if:NTF \l_color_verbP_bool
    {
      \IfNoValueTF{#1}
        {\textcolor{verbcolor}{#2}\textsuperscript{\textbf{P}}}     % Nur Textfarbe + P
        {\cbox{verbcolor}{white}{#2}\textsuperscript{\textbf{P}}}   % Box-Hintergrund + P
    }
    {#2\textsuperscript{\textbf{P}}}                                % Nur P, keine Farbe
}

\ExplSyntaxOff

