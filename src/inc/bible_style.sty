\newcommand{\tmpbibtext}[3]{\textbf{\bibleverse{#2}(#3)}\quad(\bibtit{#1})}
\newenvironment{bibelbox}[3]{%
  \begin{tcolorbox}[
      title=\tmpbibtext{#1}{#2}{#3},
      colback=white,
      colframe=black!25!white,
      width=\textwidth,
      before skip=1em,
      after skip=1em,
      fonttitle=\bfseries,
      sharp corners
    ]
    }{%
  \end{tcolorbox}
}

\newcommand{\biblezit}[2]{%
  \bib{SCHL}
  \bibleverse{#1}(#2)
}

