
\RequirePackage{colors}

\usetikzlibrary{positioning}

\newcommand{\bib}[1]{%
  \IfStrEqCase{#1}{%
    {EI}{Einheitsübersetzung}%
      {SCHL}{Schlachter 2000}%
      {HFA}{Hoffnung für Alle}%
      {ELB}{Elbfelder}%
      {GR}{Griechisch}%
      {LUT}{Luther 2017}%
      {NUE}{Neue ev. Übersetzung}%
      {BDF}{Bibel Deutsche Fassung}%
      {ESR}{ESRA Bibel}%
  }[\textbf{#1}]%
}

% Makros für Bibelzitate
\newcommand{\bibtit}[1]{\large\bib{#1}}
\newcommand{\tmpbib}{Hello}

\newenvironment{bibeltext}[3]{%
  \quote \begin{itshape}
    (\bibtit{#1})\newline
    \renewcommand{\tmpbib}{\textbf{\bibleverse{#2}(#3)}}
    }{%
    \newline
    \tmpbib
  \end{itshape}
  \endquote
}

\newcommand{\tmpbibtext}[3]{\textbf{\bibleverse{#2}(#3)}\quad(\bibtit{#1})}
\newenvironment{bibelbox}[3]{%
  \begin{tcolorbox}[
      title=\tmpbibtext{#1}{#2}{#3},
      colback=white,
      colframe=black!25!white,
      width=\textwidth,
      before skip=1em,
      after skip=1em,
      fonttitle=\bfseries,
      sharp corners
    ]
    }{%
  \end{tcolorbox}
}

\newcommand{\biblezit}[2]{%
  \bib{SCHL}
  \bibleverse{#1}(#2)
}

% Herr zu HERR
 \newcommand{\herr}{HERR}

 % Versnummer verlinken
\newcommand{\verslink}[3]{%
  \begingroup
  \edef\url{https://www.esrabibel.de/#1#2\%2C#3}%
  \uline{\href{\url}{#2,#3}}%
  \endgroup
}




