% colors.sty
% Zentrale Farbdefinitionen für alle LaTeX-Projekte
% Autor: OTS
% Version: 1.0

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{colors}[2026/02/28 Zentrale Farbdefinitionen]
\RequirePackage{varwidth}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% HAUPTFARBEN FÜR GRAMMATISCHE KATEGORIEN
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Personen
\definecolor{personcolor}{RGB}{100,100,205}    % Blau für Personen rgb(100,100,205)

% Ortsangaben
\definecolor{ortcolor}{RGB}{255,0,255}         % Magenta für Orte rgb(255,0,255)

% Verben
\definecolor{verbcolor}{RGB}{50,205,50}        % Grün für Verben (normal) rgb(50,205,50)
\definecolor{verbimperativcolor}{RGB}{226,211,85}   % Gelb für Imperativ rgb(226, 211, 82)
\definecolor{verbkonjunktivcolor}{RGB}{255,0,0}    % Rot für Konjunktiv rgb(255,0,0)
% Passiv = verbcolor + Superscript "P"

% Nomen
\definecolor{nomencolor}{RGB}{255,140,0}       % Orange für Nomen rgb(255,140,0)

% Konjunktionen
\definecolor{konjunktioncolor}{RGB}{255,0,0}   % Rot für Konjunktionen rgb(255,0,0)

% Präpositionen
\definecolor{praepositioncolor}{RGB}{0,0,255}  % Blau für Präpositionen rgb(0,0,255)

% Annotationen
\definecolor{annotationcolor}{RGB}{128,128,128} % Grau für Annotationen rgb(128,128,128)

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% THEOLOGISCHE KONZEPT-FARBEN
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\definecolor{gnade}{RGB}{180,210,255}      % sanftes Himmelsblau rgb(180,210,255)
\definecolor{gericht}{RGB}{255,180,180}    % mildes Rot rgb(255,180,180)
\definecolor{heiligkeit}{RGB}{255,240,180} % warmes Gold rgb(255,240,180)
\definecolor{bund}{RGB}{220,180,255}       % Purpur/Lila rgb(220,180,255)
\definecolor{infos}{RGB}{200,255,200}      % weiches Grün rgb(200,255,200)
\definecolor{betonung}{RGB}{255,200,200}   % zartes Rosa rgb(255,200,200)

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% STANDARD-BASISFARBEN (für Kompatibilität)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\definecolor{rot}{RGB}{255,0,0}            % Rot rgb(255,0,0)
\definecolor{gelb}{RGB}{255,255,0}         % Gelb rgb(255,255,0)
\definecolor{gruen}{RGB}{50,205,50}        % Grün rgb(50,205,50)
\definecolor{blau}{RGB}{100,100,205}       % Blau rgb(100,100,205)
\definecolor{magenta}{RGB}{255,0,255}      % Magenta rgb(255,0,255)
\definecolor{orange}{RGB}{255,140,0}       % Orange rgb(255,140,0)
\definecolor{lila}{RGB}{220,180,255}       % Lila rgb(220,180,255)
\definecolor{rosa}{RGB}{238,153,239}       % Rosa rgb(238,153,239)

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% HILFSMAKROS FÜR FARBIGE BOXEN
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Colorbox-Makro
% Verwendung: \cbox{Hintergrundfarbe}{Textfarbe}{Text}
\newcommand{\cbox}[3]{%
  \colorbox{#1}{%
    \begin{varwidth}{\dimexpr\linewidth-2\fboxsep\relax}
      \textcolor{#2}{#3}%
    \end{varwidth}%
  }%
}

% Farbige Box mit Text- und Hintergrundfarbe
% Verwendung: \btc{Hintergrundfarbe}{Textfarbe}{Text}
\newcommand{\btc}[3]{%
  \colorbox{#1}{%
    \begin{varwidth}{\dimexpr\linewidth-2\fboxsep\relax}
      \textcolor{#2}{#3}%
    \end{varwidth}%
  }%
}

% Highlight mit Hintergrundfarbe (optional)
% Verwendung: \bt[Farbe]{Text} oder \bt{Text}
\newcommand{\bt}[2][yellow]{%
  \colorbox{#1}{%
    \begin{varwidth}{\dimexpr\linewidth-2\fboxsep\relax}
      \textcolor{black}{#2}%
    \end{varwidth}%
  }%
}

\endinput
