% ------------------------------------------------------------
% Hilfsmakro für farbige Boxen (mehrzeilig, keine hbox-Fehler)
% \newcommand{\cbox}[3]{%
%   \colorbox{#1}{%
%     \begin{varwidth}{\dimexpr\linewidth-2\fboxsep\relax}
%       \textcolor{#2}{#3}%
%     \end{varwidth}%
%   }%
% }

\newcommand{\cbox}[3]{%
  \colorbox{#1}{%
    \begin{varwidth}{\dimexpr\linewidth-2\fboxsep\relax}
      \textcolor{#2}{#3}%
    \end{varwidth}%
  }%
}

% Zeilenumbruch in Boxen erlauben (für tcolorbox)
% \newtcbox{\cbox}[3]{on line, colback=#1, coltext=#2, boxrule=0pt, arc=0mm, left=1pt, right=1pt, top=1pt, bottom=1pt, boxsep=0pt, enhanced, breakable}
% % ------------------------------------------------------------
% Hauptbefehle: Wort einfärben ODER markieren
% Syntax:
%   \verbN{Text}       -> Textfarbe in Grundfarbe
%   \verbN[b]{Text}    -> Markierung in Pastellfarbe
%   \verbN[p]{Text}    -> Textfarbe in Pastellfarbe
%   \verbN[b,p]{Text}  -> Markierung in Pastellfarbe
%   \verbN[b,n]{Text}  -> Markierung in Neonfarbe

\ExplSyntaxOn
\tl_new:N \l_mark_mode_tl
\tl_new:N \l_mark_palette_tl
\tl_new:N \l_mark_selected_color_tl

\cs_new_protected:Npn \mark_parse_options:n #1 {
  \tl_set:Nn \l_mark_mode_tl {t}
  \tl_clear:N \l_mark_palette_tl
  \tl_if_blank:nF {#1} {
    \clist_map_inline:nn {#1} {
      \str_case:enF { \tl_trim_spaces:n {##1} } {
        {b} { \tl_set:Nn \l_mark_mode_tl {b} }
        {t} { \tl_set:Nn \l_mark_mode_tl {t} }
        {g} { \tl_set:Nn \l_mark_palette_tl {g} }
        {grund} { \tl_set:Nn \l_mark_palette_tl {g} }
        {n} { \tl_set:Nn \l_mark_palette_tl {n} }
        {neon} { \tl_set:Nn \l_mark_palette_tl {n} }
        {p} { \tl_set:Nn \l_mark_palette_tl {p} }
        {pastell} { \tl_set:Nn \l_mark_palette_tl {p} }
      } { }
    }
  }
}

\cs_new:Npn \mark_default_palette: {
  \tl_if_blank:VTF \l_mark_palette_tl
    {
      \tl_if_eq:VnTF \l_mark_mode_tl {b} {p} {g}
    }
    {\l_mark_palette_tl}
}

\cs_new_protected:Npn \mark_select_color:nnn #1#2#3 {
  \tl_set:Nx \l_mark_selected_color_tl {
    \str_case:enF { \mark_default_palette: } {
      {g} {#1}
      {n} {#2}
      {p} {#3}
    } {#1}
  }
}

\cs_new_protected:Npn \mark_apply:nnnnn #1#2#3#4#5 {
  \mark_parse_options:n {#1}
  \mark_select_color:nnn {#2} {#3} {#4}
  \marktext{\l_mark_mode_tl}{\l_mark_selected_color_tl}{#5}
}

\cs_new_protected:Npn \mark_apply_box:nnnnn #1#2#3#4#5 {
  \mark_parse_options:n {#1}
  \mark_select_color:nnn {#2} {#3} {#4}
  \tl_if_eq:VnTF \l_mark_mode_tl {b}
    {\cbox{\l_mark_selected_color_tl}{black}{#5}}
    {\textcolor{\l_mark_selected_color_tl}{#5}}
}

% VerbN (grün)
\NewDocumentCommand{\verbN}{O{} +m}{%
  \bool_if:NTF \l_mark_verbN_bool
    {\mark_apply:nnnnn {#1} {grundgruen} {neongruen} {pastellgruen} {#2}}
    {#2}%
}
% VerbI (gelb)
\NewDocumentCommand{\verbI}{O{} +m}{%
  \bool_if:NTF \l_mark_verbI_bool
    {\mark_apply:nnnnn {#1} {grundgelb} {neongelb} {pastellgelb} {#2}}
    {#2}%
}
% VerbP (grün + P)
\NewDocumentCommand{\verbP}{O{} +m}{%
  \bool_if:NTF \l_mark_verbP_bool
    {\mark_apply:nnnnn {#1} {grundgruen} {neongruen} {pastellgruen} {#2}\textsuperscript{\textbf{P}}}
    {#2\textsuperscript{\textbf{P}}}%
}
% Konj (rot)
\NewDocumentCommand{\konj}{O{} +m}{%
  \bool_if:NTF \l_mark_konj_bool
    {\mark_apply:nnnnn {#1} {grundrot} {neonrot} {pastellrot} {#2}}
