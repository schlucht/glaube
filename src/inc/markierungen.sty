% Schalter zum Ein-/Ausschalten der Markierungen
% Beispiel: \markierungenOff, \markierungenOn
\ExplSyntaxOn
\cs_new_protected:Npn \markierungen_set_all_false: {
  \bool_set_false:N \l_mark_verbN_bool
  \bool_set_false:N \l_mark_verbI_bool
  \bool_set_false:N \l_mark_verbP_bool
  \bool_set_false:N \l_mark_konj_bool
  \bool_set_false:N \l_mark_ort_bool
  \bool_set_false:N \l_mark_person_bool
  \bool_set_false:N \l_mark_betonung_bool
  \bool_set_false:N \l_mark_info_bool
  \bool_set_false:N \l_mark_lied_bool
  \bool_set_false:N \l_mark_beten_bool
}
\cs_new_protected:Npn \markierungen_set_all_true: {
  \bool_set_true:N \l_mark_verbN_bool
  \bool_set_true:N \l_mark_verbI_bool
  \bool_set_true:N \l_mark_verbP_bool
  \bool_set_true:N \l_mark_konj_bool
  \bool_set_true:N \l_mark_ort_bool
  \bool_set_true:N \l_mark_person_bool
  \bool_set_true:N \l_mark_betonung_bool
  \bool_set_true:N \l_mark_info_bool
  \bool_set_true:N \l_mark_lied_bool
  \bool_set_true:N \l_mark_beten_bool
}
\NewDocumentCommand{\markierungenOff}{}{\markierungen_set_all_false:}
\NewDocumentCommand{\markierungenOn}{}{\markierungen_set_all_true:}
\ExplSyntaxOff

