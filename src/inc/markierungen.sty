% Zentrales Makro: \marktext
% #1 = Modus ('b' für Background, sonst Textfarbe), #2 = Farbe, #3 = Text
\newcommand{\marktext}[3]{%
  \ifthenelse{\equal{#1}{b}}% 
    {\sethlcolor{#2}\hl{#3}}% Hintergrund
    {\textcolor{#2}{#3}}% Textfarbe
}

