\NeedsTeXFormat{LaTeX2e}

\makeatletter
\edef\mybibcommonprovidesname{\@currpath\@currname}
\expandafter\ProvidesPackage\expandafter{\mybibcommonprovidesname}[2026/06/05 Gemeinsame Bibel-Vorlage]

% Pfad-Handling für \input und \import
\edef\mybibcommoncurrpath{{\@currpath}}
\@ifundefined{input@path}{%
  \def\mybibcommonoldinputpath{}%
}{%
  \let\mybibcommonoldinputpath\input@path
}
\edef\input@path{\mybibcommoncurrpath\mybibcommonoldinputpath}
\makeatother

