% Input-Pfad setzen
\newcommand{\setincpath}[1]{%
  \makeatletter
  \def\input@path{{#1}}%
  \makeatother
}

% einfacher Block
\newenvironment{block}[1][]{%
  \vspace{0.5em}%
  \noindent\textbf{#1}\par%
  \vspace{0.0em}%
}{%
  \vspace{1.2em}\par\noindent%
}