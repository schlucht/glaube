% ------------------------------------------------

\RequirePackage{bibleref-german}


\makeatletter

% Zusatzfelder
\newcommand{\bibleref}[1]{\def\@bibleref{#1}}

% Default (falls nichts gesetzt)
\newcommand{\@bibleref}{}

\newcommand{\mytitlepage}{
  \begin{titlepage}
    \centering

    \vspace*{2cm}

    % Logo (falls gesetzt)
    \ifx\headerlogo\empty\else
    \headerlogo
    \fi

    % Titel
    {\Huge \bfseries \@title \par}
    \vspace{0.8cm}

    % Untertitel / Erklärung
    \ifx\@subtitle\empty\else
      {\Large \itshape \@subtitle \par}
      \vspace{1.5cm}
    \fi

    % Bibelstelle
    \ifx\@bibleref\empty\else
    {\large \textbf{\@bibleref} \par}
    \vspace{2cm}
    \fi

    % Autor
    {\large \@author \par}
    \vspace{0.5cm}

    % Datum
    {\normalsize \@date \par}

    \vfill

  \end{titlepage}
}

\makeatother

